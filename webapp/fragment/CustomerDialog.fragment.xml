<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">

    <Dialog
        id="dlgCustomer"
        afterClose="onDialogAfterClose">

        <content>

            <form:SimpleForm
                id="frmCustomer"
                editable="false">

                <Label
                    id="lblCustomerID"
                    text="{i18n>fieldCustomerID}"
                    visible="{= !${view>/isCreate} }"/>

                <Text
                    id="txtDlgCustomerID"
                    text="{ID}"
                    visible="{= !${view>/isCreate} }"/>

                <Label
                    id="lblName"
                    text="{i18n>fieldName}" />

                <Text
                    id="txtDlgName"
                    text="{Name}"
                    visible="{= !${view>/editMode}}" />

                <Input
                    id="inpDlgName"
                    value="{edit>/Name}"
                    visible="{view>/editMode}"
                    liveChange="onNameLiveChange"
                    valueState="{view>/nameState}"
                    valueStateText="{i18n>msgFieldRequired}" />

                <Label
                    id="lblCity"
                    text="{i18n>fieldCity}" />

                <Text
                    id="txtDlgCity"
                    text="{City}"
                    visible="{= !${view>/editMode}}" />

                <Input
                    id="inpDlgCity"
                    value="{edit>/City}"
                    visible="{view>/editMode}"
                    liveChange="onCityLiveChange"
                    valueState="{view>/cityState}"
                    valueStateText="{i18n>msgFieldRequired}" />

                <Label
                    id="lblPhone"
                    text="{i18n>fieldPhone}" />

                <Text
                    id="txtDlgPhone"
                    text="{Phone}"
                    visible="{= !${view>/editMode}}" />

                <Input
                    id="inpDlgPhone"
                    value="{edit>/Phone}"
                    visible="{view>/editMode}"
                    liveChange="onPhoneLiveChange"
                    valueState="{view>/phoneState}"
                    valueStateText="{view>/phoneStateText}" />

            </form:SimpleForm>

        </content>

        <buttons>

            <Button
                id="btnDelete"
                text="{i18n>deleteButton}"
                type="Negative"
                press="onDelete"
                visible="{= !${view>/isCreate} }" />

            <Button
                id="btnEdit"
                text="{i18n>editButton}"
                press="onEdit"
                visible="{= !${view>/editMode}}" />

            <Button
                id="btnSave"
                text="{i18n>saveButton}"
                press="onSave"
                visible="{view>/editMode}" />

            <Button
                id="btnCancel"
                text="{i18n>cancelButton}"
                press="onCancel"
                visible="{view>/editMode}" />

            <Button
                id="btnClose"
                text="{i18n>closeButton}"
                press="onCloseDialog"
                visible="{= !${view>/editMode}}" />

        </buttons>

    </Dialog>

</core:FragmentDefinition>