<mvc:View
    controllerName="com.demo.customer.customerui5.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <App id="app">
        <pages>
            <Page
                id="page"
                title="{i18n>pageTitle}"
                busy="{view>/busy}"
                busyIndicatorDelay="0">

                <content>

                    <VBox id="vbxMain">

                        <SearchField
                            id="sfCustomer"
                            width="40%"
                            placeholder="{i18n>searchPlaceholder}"
                            search="onSearch" />

                        <Button
                            id="btnReset"
                            text="{i18n>resetButton}"
                            press="onReset" />

                        <Table
                            id="tblCustomer"
                            items="{/Customers}"
                            noDataText="{i18n>noDataText}"
                            mode="MultiSelect"
                            selectionChange="onSelectionChange">

                            <headerToolbar>

                                <OverflowToolbar id="tbCustomer">

                                    <Title
                                        id="ttlCustomer"
                                        text="{i18n>customerListTitle}" />

                                    <ToolbarSpacer id="tbsCustomer" />

                                    <Button
                                        id="btnDeleteSelected"
                                        text="{i18n>deleteButton}"
                                        icon="sap-icon://delete"
                                        type="Reject"
                                        enabled="{view>/hasSelection}"
                                        press="onDeleteSelected" />

                                    <Button
                                        id="btnAdd"
                                        text="{i18n>addButton}"
                                        icon="sap-icon://add"
                                        press="onAdd" />

                                    <MenuButton
                                        id="btnSort"
                                        text="{view>/sortButtonText}"
                                        icon="{view>/sortButtonIcon}">
                                    
                                        <menu>
                                            <Menu id="menuSort">
                                                <items>
                                    
                                                    <MenuItem
                                                        id="miSortClear"
                                                        text="{i18n>sortClear}"
                                                        icon="sap-icon://sort-clear"
                                                        press="onSortClear"
                                                        enabled="{= !!${view>/sortPath} }" />
                                    
                                                    <MenuItem
                                                        id="miSortByCustomerID"
                                                        text="{i18n>sortByCustomerID}"
                                                        press="onSortSelect">
                                                        <customData>
                                                            <core:CustomData
                                                                key="sortPath"
                                                                value="ID" />
                                                            <core:CustomData
                                                                key="sortLabel"
                                                                value="{i18n>sortByCustomerID}" />
                                                        </customData>
                                                    </MenuItem>
                                    
                                                    <MenuItem
                                                        id="miSortByName"
                                                        text="{i18n>sortByName}"
                                                        press="onSortSelect">
                                                        <customData>
                                                            <core:CustomData
                                                                key="sortPath"
                                                                value="Name" />
                                                            <core:CustomData
                                                                key="sortLabel"
                                                                value="{i18n>sortByName}" />
                                                        </customData>
                                                    </MenuItem>
                                    
                                                    <MenuItem
                                                        id="miSortByCity"
                                                        text="{i18n>sortByCity}"
                                                        press="onSortSelect">
                                                        <customData>
                                                            <core:CustomData
                                                                key="sortPath"
                                                                value="City" />
                                                            <core:CustomData
                                                                key="sortLabel"
                                                                value="{i18n>sortByCity}" />
                                                        </customData>
                                                    </MenuItem>
                                    
                                                    <MenuItem
                                                        id="miSortByPhone"
                                                        text="{i18n>sortByPhone}"
                                                        press="onSortSelect">
                                                        <customData>
                                                            <core:CustomData
                                                                key="sortPath"
                                                                value="Phone" />
                                                            <core:CustomData
                                                                key="sortLabel"
                                                                value="{i18n>sortByPhone}" />
                                                        </customData>
                                                    </MenuItem>
                                    
                                                </items>
                                            </Menu>
                                        </menu>
                                    </MenuButton>

                                </OverflowToolbar>

                            </headerToolbar>

                            <columns>
                                <Column id="colCustomerID" importance="High">
                                    <Text id="txtHeaderCustomerID" text="{i18n>colCustomerID}" />
                                </Column>

                                <Column id="colName" importance="High">
                                    <Text id="txtHeaderName" text="{i18n>colName}" />
                                </Column>

                                <Column
                                    id="colCity"
                                    importance="Medium"
                                    demandPopin="true"
                                    minScreenWidth="600px"
                                    popinDisplay="Inline">
                                    <Text id="txtHeaderCity" text="{i18n>colCity}" />
                                </Column>

                                <Column
                                    id="colPhone"
                                    importance="Low"
                                    demandPopin="true"
                                    minScreenWidth="800px"
                                    popinDisplay="Inline">
                                    <Text id="txtHeaderPhone" text="{i18n>colPhone}" />
                                </Column>
                            </columns>

                            <items>
                                <ColumnListItem
                                    id="cliCustomer"
                                    type="Navigation"
                                    press="onItemPress">
                                    <cells>
                                        <Text id="txtCustomerID" text="{ID}" />
                                        <Text id="txtName" text="{Name}" />
                                        <Text id="txtCity" text="{City}" />
                                        <Text id="txtPhone" text="{Phone}" />
                                    </cells>
                                </ColumnListItem>
                            </items>

                        </Table>

                    </VBox>

                </content>

            </Page>
        </pages>
    </App>

</mvc:View>